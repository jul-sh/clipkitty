        "fr": { "stringUnit": { "state": "translated", "value": "Police de l’app" } },
        "ja": { "stringUnit": { "state": "translated", "value": "アプリのフォント" } },
        "ko": { "stringUnit": { "state": "translated", "value": "앱 글꼴" } },
        "pt-BR": { "stringUnit": { "state": "translated", "value": "Fonte do app" } },
        "ru": { "stringUnit": { "state": "translated", "value": "Шрифт приложения" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "应用字体" } },
        "zh-Hant": { "stringUnit": { "state": "translated", "value": "應用程式字體" } }
      }
    },
    "Drag the handle to set how much space history can use. When it fills, the oldest items are overwritten.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe den Regler, um festzulegen, wie viel Speicherplatz der Verlauf belegen darf. Ist er voll, werden die ältesten Objekte überschrieben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag the handle to set how much space history can use. When it fills, the oldest items are overwritten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra el control para definir cuánto espacio puede usar el historial. Cuando se llena, se sobrescriben los elementos más antiguos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser la poignée pour définir l’espace que l’historique peut utiliser. Une fois plein, les éléments les plus anciens sont remplacés."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ハンドルをドラッグして、履歴が使用できる容量を設定します。いっぱいになると、最も古い項目から上書きされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "핸들을 드래그하여 기록이 사용할 수 있는 공간을 설정하세요. 공간이 가득 차면 가장 오래된 항목부터 덮어씁니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste o controle para definir quanto espaço o histórico pode usar. Quando encher, os itens mais antigos são substituídos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите ползунок, чтобы задать, сколько места может занимать история. Когда оно заполнится, самые старые элементы перезаписываются."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖动滑块以设置历史记录可用的空间。空间用满后，最旧的项目会被覆盖。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖曳控制點以設定記錄可用的空間。空間用滿後，最舊的項目會被覆寫。"
          }
        }
      }
    },
    "Drag to set the storage limit": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen, um das Speicherlimit festzulegen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to set the storage limit"
          }
        },
        "es": {
          "stringUnit": {
