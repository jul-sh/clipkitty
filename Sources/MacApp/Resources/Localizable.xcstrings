    "ClipKitty needs accessibility permission to paste items directly into apps by simulating keyboard shortcuts (⌘V).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty benötigt die Bedienungshilfen-Berechtigung, um Einträge durch Simulation von Tastaturkurzbefehlen (⌘V) direkt in Apps einzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty needs accessibility permission to paste items directly into apps by simulating keyboard shortcuts (⌘V)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty necesita permiso de accesibilidad para pegar elementos directamente en las apps simulando atajos de teclado (⌘V)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty a besoin de l'autorisation d'accessibilité pour coller des éléments directement dans les apps en simulant des raccourcis clavier (⌘V)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKittyは、キーボードショートカット（⌘V）をシミュレートしてアプリに直接ペーストするために、アクセシビリティの許可が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty는 키보드 단축키(⌘V)를 시뮬레이션하여 앱에 직접 붙여넣기 위해 손쉬운 사용 권한이 필요합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O ClipKitty precisa de permissão de acessibilidade para colar itens diretamente nos apps simulando atalhos de teclado (⌘V)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty требуется разрешение Универсального доступа для вставки элементов непосредственно в приложения путём имитации сочетаний клавиш (⌘V)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 需要辅助功能权限，以通过模拟键盘快捷键（⌘V）将项目直接粘贴到应用中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 需要輔助使用權限，以透過模擬鍵盤快捷鍵（⌘V）將項目直接貼上到應用程式中。"
          }
        }
      }
    },
    "ClipKitty runs in an isolated environment, protecting your privacy and keeping your data secure.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty wird in einer isolierten Umgebung ausgeführt, um Ihre Privatsphäre zu schützen und Ihre Daten zu sichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty runs in an isolated environment, protecting your privacy and keeping your data secure."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty se ejecuta en un entorno aislado, protegiendo tu privacidad y manteniendo tus datos seguros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty s'exécute dans un environnement isolé, protégeant votre confidentialité et sécurisant vos données."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKittyは隔離された環境で動作し、プライバシーを保護してデータを安全に保ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty는 격리된 환경에서 실행되어 개인 정보를 보호하고 데이터를 안전하게 유지합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O ClipKitty é executado em um ambiente isolado, protegendo sua privacidade e mantendo seus dados seguros."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty работает в изолированной среде, защищая вашу конфиденциальность и обеспечивая безопасность данных."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 在隔离环境中运行，保护您的隐私并确保数据安全。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 在隔離環境中執行，保護您的隱私並確保資料安全。"
          }
        }
      }
    },
    "ClipKitty will detect when permission is granted.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty erkennt automatisch, wenn die Berechtigung erteilt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty will detect when permission is granted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty detectará cuando se conceda el permiso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty détectera automatiquement lorsque l'autorisation sera accordée."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKittyは許可が付与されると自動的に検出します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty는 권한이 부여되면 자동으로 감지합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O ClipKitty detectará automaticamente quando a permissão for concedida."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty автоматически определит, когда разрешение будет предоставлено."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 会在权限授予后自动检测到。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 會在權限授予後自動偵測到。"
          }
        }
      }
    },
    "ClipKitty will paste items directly into the previous app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty setzt Einträge direkt in die vorherige App ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty will paste items directly into the previous app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty pegará los elementos directamente en la aplicación anterior."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty collera les éléments directement dans l'application précédente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKittyは直前のアプリに項目を直接ペーストします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty가 이전 앱에 항목을 직접 붙여넣습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O ClipKitty colará os itens diretamente no app anterior."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty будет вставлять элементы непосредственно в предыдущее приложение."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 将直接把项目粘贴到上一个应用中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty 會直接將項目貼入先前的 App。"
          }
        }
      }
    },
    "Clipboard History Search": {
      "localizations": {
        "de": {
