            "value": "ベータ版アップデートを受け取る"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "베타 업데이트 받기"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Receber atualizacoes beta"
          }
        },
        "ru": {
