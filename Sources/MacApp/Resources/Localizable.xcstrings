    "Copy selected items to the system clipboard to paste manually later.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgewählte Einträge in die Zwischenablage kopieren, um sie später manuell einzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copy selected items to the system clipboard to paste manually later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar los elementos seleccionados al portapapeles del sistema para pegarlos manualmente después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copier les éléments sélectionnés dans le presse-papiers pour les coller manuellement plus tard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した項目をシステムクリップボードにコピーして、後で手動でペーストします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 항목을 시스템 클립보드에 복사하여 나중에 수동으로 붙여넣습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiar os itens selecionados para a área de transferência do sistema para colar manualmente depois."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Скопировать выбранные элементы в системный буфер обмена для последующей ручной вставки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将选中的项目复制到系统剪贴板，以便稍后手动粘贴。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將選取的項目複製到系統剪貼簿，以便稍後手動貼上。"
          }
        }
      }
    },
    "Could not determine iCloud account status.": {
