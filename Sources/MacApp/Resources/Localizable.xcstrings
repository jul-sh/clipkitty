    "Beta releases are for testing new features early. Turn this on to try the latest improvements before they roll out to everyone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta-Versionen dienen zum frühen Testen neuer Funktionen. Aktivieren Sie dies, um die neuesten Verbesserungen auszuprobieren, bevor sie für alle ausgerollt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta releases are for testing new features early. Turn this on to try the latest improvements before they roll out to everyone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las versiones beta son para probar nuevas funciones antes. Activa esto para probar las últimas mejoras antes de que se publiquen para todos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les versions beta permettent de tester les nouvelles fonctionnalités en avant-première. Activez ceci pour essayer les dernières améliorations avant leur déploiement général."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ベータ版は新機能を早期にテストするためのものです。これをオンにすると、一般公開前に最新の改善を試すことができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "베타 릴리스는 새로운 기능을 미리 테스트하기 위한 것입니다. 이 옵션을 켜면 모든 사용자에게 배포되기 전에 최신 개선 사항을 먼저 경험할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As versões beta são para testar novos recursos antecipadamente. Ative isto para experimentar as últimas melhorias antes do lançamento para todos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Бета-версии предназначены для раннего тестирования новых функций. Включите это, чтобы попробовать последние улучшения до их публикации для всех."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta 版本用于提前测试新功能。启用此选项可在正式发布前体验最新改进。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta 版本用於提前測試新功能。啟用此選項可在正式發布前體驗最新改進。"
          }
        }
      }
    },
