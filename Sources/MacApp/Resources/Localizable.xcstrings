    "Try restarting ClipKitty. If the problem persists, check disk space.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuchen Sie, ClipKitty neu zu starten. Wenn das Problem weiterhin besteht, überprüfen Sie den Speicherplatz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try restarting ClipKitty. If the problem persists, check disk space."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Intente reiniciar ClipKitty. Si el problema persiste, compruebe el espacio en disco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de redémarrer ClipKitty. Si le problème persiste, vérifiez l’espace disque."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKittyを再起動してください。問題が解決しない場合は、ディスク容量を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "ClipKitty를 재시작해 보십시오. 문제가 지속되면 디스크 공간을 확인하십시오."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tente reiniciar o ClipKitty. Se o problema persistir, verifique o espaço em disco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Попробуйте перезапустить ClipKitty. Если проблема не исчезнет, проверьте свободное место на диске."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请尝试重新启动 ClipKitty。如果问题仍然存在，请检查磁盘空间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請嘗試重新啟動 ClipKitty。如果問題仍然存在，請檢查磁碟空間。"
