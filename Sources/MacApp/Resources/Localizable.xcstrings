          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "拖曳以設定儲存空間上限"
          }
        }
      }
    },
    "History already uses more space than the new limit. The oldest items will be removed to fit.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Verlauf belegt bereits mehr Speicherplatz als das neue Limit. Die ältesten Objekte werden entfernt, damit es passt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "History already uses more space than the new limit. The oldest items will be removed to fit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El historial ya usa más espacio que el nuevo límite. Se eliminarán los elementos más antiguos para ajustarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’historique utilise déjà plus d’espace que la nouvelle limite. Les éléments les plus anciens seront supprimés pour s’y conformer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴はすでに新しい上限を超える容量を使用しています。収まるように最も古い項目から削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록이 이미 새 한도보다 많은 공간을 사용하고 있습니다. 맞추기 위해 가장 오래된 항목이 삭제됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O histórico já usa mais espaço que o novo limite. Os itens mais antigos serão removidos para caber."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История уже занимает больше места, чем новый лимит. Самые старые элементы будут удалены."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "历史记录已占用超过新限额的空间。将删除最旧的项目以符合限额。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄已佔用超過新上限的空間。將移除最舊的項目以符合上限。"
          }
        }
      }
    },
