    },
    "Copy something, or open ClipKitty to load your recent clips — they'll appear here." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kopiere etwas oder öffne ClipKitty, um deine letzten Clips zu laden — sie erscheinen dann hier."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copy something, or open ClipKitty to load your recent clips — they'll appear here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copia algo o abre ClipKitty para cargar tus clips recientes: aparecerán aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copiez quelque chose ou ouvrez ClipKitty pour charger vos clips récents — ils apparaîtront ici."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "何かをコピーするか、ClipKitty を開いて最近のクリップを読み込むと、ここに表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무언가를 복사하거나 ClipKitty를 열어 최근 클립을 불러오면 여기에 표시됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Copie algo ou abra o ClipKitty para carregar seus clipes recentes — eles aparecerão aqui."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скопируйте что-нибудь или откройте ClipKitty, чтобы загрузить недавние фрагменты — они появятся здесь."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拷贝一些内容，或打开 ClipKitty 载入最近的剪贴项，它们会显示在这里。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拷貝一些內容，或開啟 ClipKitty 載入最近的剪貼項目，它們會顯示在這裡。"
          }
        }
      }
    },
    "In the Settings app, go to ClipKitty → Keyboards and turn on Allow Full Access. The keyboard reads your clip history and saves new clips to it; nothing leaves your device." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gehe in der Einstellungen-App zu ClipKitty → Tastaturen und aktiviere „Vollzugriff erlauben“. Die Tastatur liest deinen Clip-Verlauf und speichert neue Clips darin; nichts verlässt dein Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the Settings app, go to ClipKitty → Keyboards and turn on Allow Full Access. The keyboard reads your clip history and saves new clips to it; nothing leaves your device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En la app Ajustes, ve a ClipKitty → Teclados y activa \"Permitir acceso total\". El teclado lee tu historial de clips y guarda clips nuevos en él; nada sale de tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans l’app Réglages, accédez à ClipKitty → Claviers et activez « Autoriser l’accès complet ». Le clavier lit l’historique de vos clips et y enregistre les nouveaux ; rien ne quitte votre appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定アプリで ClipKitty →「キーボード」を開き、「フルアクセスを許可」をオンにします。キーボードはクリップ履歴を読み取り、新しいクリップを保存します。データが端末の外に送信されることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설정 앱에서 ClipKitty → 키보드로 이동해 \"전체 접근 허용\"을 켭니다. 키보드는 클립 기록을 읽고 새 클립을 저장합니다. 어떤 것도 기기 밖으로 나가지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No app Ajustes, vá em ClipKitty → Teclados e ative \"Permitir Acesso Total\". O teclado lê seu histórico de clipes e salva novos clipes nele; nada sai do seu dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В приложении «Настройки» откройте ClipKitty → «Клавиатуры» и включите «Разрешить полный доступ». Клавиатура читает историю фрагментов и сохраняет в неё новые; ничего не покидает ваше устройство."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在“设置” App 中前往 ClipKitty →“键盘”，并开启“允许完全访问”。该键盘会读取你的剪贴历史并保存新的剪贴项；任何内容都不会离开你的设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「設定」App 中前往 ClipKitty →「鍵盤」，並開啟「允許完整取用」。此鍵盤會讀取你的剪貼記錄並儲存新的剪貼項目；任何內容都不會離開你的裝置。"
          }
        }
      }
    },
    "Tap the globe key on any keyboard to switch to ClipKitty. New clipboard content is saved to your history whenever the keyboard opens." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf einer beliebigen Tastatur auf die Globus-Taste, um zu ClipKitty zu wechseln. Neue Inhalte der Zwischenablage werden beim Öffnen der Tastatur in deinem Verlauf gespeichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the globe key on any keyboard to switch to ClipKitty. New clipboard content is saved to your history whenever the keyboard opens."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca la tecla del globo en cualquier teclado para cambiar a ClipKitty. El contenido nuevo del portapapeles se guarda en tu historial cada vez que se abre el teclado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez la touche globe sur n’importe quel clavier pour passer à ClipKitty. Le nouveau contenu du presse-papiers est enregistré dans votre historique à chaque ouverture du clavier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どのキーボードでも地球儀キーをタップすると ClipKitty に切り替えられます。キーボードを開くたびに、クリップボードの新しい内容が履歴に保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아무 키보드에서나 지구본 키를 탭하면 ClipKitty로 전환됩니다. 키보드를 열 때마다 새로운 클립보드 내용이 기록에 저장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque na tecla de globo em qualquer teclado para mudar para o ClipKitty. O novo conteúdo da área de transferência é salvo no seu histórico sempre que o teclado é aberto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коснитесь клавиши с глобусом на любой клавиатуре, чтобы переключиться на ClipKitty. Новое содержимое буфера обмена сохраняется в историю при каждом открытии клавиатуры."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在任意键盘上轻点地球键即可切换到 ClipKitty。每次打开键盘时，剪贴板中的新内容都会保存到你的历史记录。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在任一鍵盤上點一下地球鍵即可切換到 ClipKitty。每次開啟鍵盤時，剪貼簿中的新內容都會儲存到你的記錄。"
          }
        }
      }
    },
