    "To streamline operations, you can allow ClipKitty to always read the clipboard." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit Abläufe schneller gehen, kannst du ClipKitty erlauben, die Zwischenablage immer zu lesen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To streamline operations, you can allow ClipKitty to always read the clipboard."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para agilizar las operaciones, puedes permitir que ClipKitty lea siempre el portapapeles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour simplifier les opérations, vous pouvez autoriser ClipKitty à toujours lire le presse-papiers."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "操作をスムーズにするため、ClipKitty が常にクリップボードを読み取れるように許可できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "작업을 더 원활하게 하려면 ClipKitty가 항상 클립보드를 읽도록 허용할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para agilizar as operações, você pode permitir que o ClipKitty leia sempre a área de transferência."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы упростить работу, можно разрешить ClipKitty всегда читать буфер обмена."
          }
        },
