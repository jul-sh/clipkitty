          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opcional: pon Pegar de otras apps en Permitir para que el teclado guarde clips nuevos sin preguntar."
          }
        },
        "fr" : {
          "stringUnit" : {
