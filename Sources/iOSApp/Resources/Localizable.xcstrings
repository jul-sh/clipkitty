        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необязательно: установите «Вставка из других приложений» на «Разрешить», чтобы клавиатура сохраняла новые фрагменты без запросов."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
