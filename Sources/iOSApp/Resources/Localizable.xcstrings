    "Optional: set Paste from Other Apps to Allow, so the keyboard can save new clips without asking." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Optional: Stelle „Einfügen von anderen Apps“ auf „Erlauben“, damit die Tastatur neue Clips ohne Nachfrage speichern kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
